DATABASE_URL=postgres://rwf:rwf_dev_password@localhost:5432/rwf_demo
RUST_LOG=info
# Dev-only password for the gateway's `/auth/login`.
ADMIN_PASSWORD=synthetic-gateway-test-password
GATEWAY_PORT=3001
LIVE_SEARCH_PORT=3000

# EdDSA JWT Keys
# -----------------
# The gateway uses Ed25519 (EdDSA) for JWT signing and verification.
# Provide the keys via environment variables, or use `--dev-keys` to
# generate an ephemeral keypair at startup (development only).
#
# Option A: Ephemeral dev keys (recommended for development)
#   Run: cargo run -p gateway-example -- --dev-keys
#   The keypair is generated fresh each time and logged at WARN level.
#
# Option B: Environment variables (production)
#   Generate a keypair with OpenSSL:
#     openssl genpkey -algorithm ED25519 -outform PEM -out private.pem
#     openssl pkey -in private.pem -pubout -outform PEM -out public.pem
#
#   Then export the PEM content:
#   JWT_PRIVATE_KEY_PEM=$(cat private.pem)
#   JWT_PUBLIC_KEY_PEM=$(cat public.pem)
#
#   NOTE: PEM values contain newlines. When using a .env file, wrap
#   the value in single quotes so the shell preserves the newlines.
#
# Example (development-only fixed keypair — do not use in production):
# JWT_PRIVATE_KEY_PEM='-----BEGIN PRIVATE KEY-----
# MC4CAQAwBQYDK2VwBCIEIBQp7/pzR0ZY+DVFTZ0x/WH6O8HeBolXGUdMX2v2XGxO
# -----END PRIVATE KEY-----'
# JWT_PUBLIC_KEY_PEM='-----BEGIN PUBLIC KEY-----
# MCowBQYDK2VwAyEADUoZlDcoIxgvgbwvhFsqI1C6iz7ZeQYW2n1waRedVd8=
# -----END PUBLIC KEY-----'
