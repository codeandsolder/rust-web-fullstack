DATABASE_URL=postgres://rwf:rwf_dev_password@localhost:5432/rwf_demo
RUST_LOG=info
# Dev-only JWT secret. Must be ≥32 bytes and NOT the literal placeholder
# "changeme-in-production" (gateway::settings rejects both). Replace in
# production with a secret from your secret manager.
JWT_SECRET=dev-jwt-secret-change-in-production-please-32-bytes
# Dev-only password for the gateway's `/auth/login`. The E2E test
# `gateway_test::auth_login_succeeds` posts exactly this value, so changing
# one without the other breaks the suite.
ADMIN_PASSWORD=synthetic-gateway-test-password
GATEWAY_PORT=3001
LIVE_SEARCH_PORT=3000
